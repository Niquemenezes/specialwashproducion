# Copia este archivo a backend/.env y completa tus valores reales.
# Este archivo SI se puede versionar. El .env real NO.

SECRET_KEY=dev_secret_key
JWT_SECRET_KEY=jwt_secret_key
DATABASE_URL=sqlite:///instance/specialwash.db
FRONTEND_URL=http://localhost:3000

# OpenAI para chatbot/redaccion de actas
OPENAI_API_KEY=sk-tu-clave-aqui
OPENAI_MODEL=gpt-4.1-mini

# Seguridad login (rate limit básico en memoria)
# 5 intentos fallidos dentro de 5 min bloquean 15 min por IP+email
LOGIN_MAX_ATTEMPTS=5
LOGIN_WINDOW_SECONDS=300
LOGIN_BLOCK_SECONDS=900
